generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id          String   @id @default(cuid())
  title       String
  date        String
  lastStudied String
  progress    Int      @default(0)
  
  // material counts
  pdfCount    Int      @default(0)
  audioCount  Int      @default(0)
  videoCount  Int      @default(0)
  imageCount  Int      @default(0)

  // generation outputs
  notes       String?   // Markdown string
  flashcards  String?   // JSON Array [{front, back}]
  quiz        String?   // JSON Array [{question, options, answer_index, explanation}]
  quest       String?   // JSON State for text-adventure
  podcast     String?   // Base64 audio string or ElevenLabs output
  visual      String?   // Mermaid DSL or JSON for visual graph
  activeModes String?   // Comma separated list of active study modes
  files       String?   // JSON array of file metadata [{name, type}]

  // progress tracking for each mode
  notesProgress       Int      @default(0) // 0-100, based on scroll position
  flashcardsProgress  Int      @default(0) // 0-100, based on cards viewed
  quizProgress        Int      @default(0) // 0-100, based on correct answers
  questProgress       Int      @default(0) // 0-100, based on quest completion
  podcastProgress     Int      @default(0) // 0-100, based on audio playback
  visualProgress      Int      @default(0) // 0-100, based on interactions
  audioProgress       Int      @default(0) // 0-100, based on audio playback

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
